{
  "name": "simple-tool-for-video-compress",
  "version": "1.0.0",
  "description": "Research-grade video compression tool with H.264/x264 experimentation capabilities",
  "main": "cli/index.js",
  "bin": {
    "vidcompress": "cli/index.js"
  },
  "scripts": {
    "start": "node cli/index.js",
    "dev": "concurrently \"npm run backend:serve\" \"npm run frontend:dev\" \"npm run worker\"",
    "backend:serve": "cd backend && php artisan serve",
    "backend:migrate": "cd backend && php artisan migrate",
    "backend:install": "cd backend && composer install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:install": "cd frontend && npm install",
    "worker": "cd backend && php artisan compression:process --watch",
    "install:all": "npm install && npm run backend:install && npm run frontend:install",
    "test": "jest",
    "lint": "eslint cli/"
  },
  "keywords": [
    "video",
    "compression",
    "h264",
    "x264",
    "ffmpeg",
    "encoding"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fluent-ffmpeg": "^2.1.2",
    "axios": "^1.6.5",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
